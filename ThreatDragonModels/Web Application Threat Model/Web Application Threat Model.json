                {
                  "id": "aef98a50-1a47-4ef7-b532-f3d4cc7820a9",
                  "title": "User Identity Spoofing",
                  "status": "Open",
                  "severity": "High",
                  "type": "Spoofing",
                  "description": "An attacker may impersonate a legitimate user by stealing or guessing authentication credentials. \nThis could allow unauthorized access to the web application and sensitive resources.",
                  "mitigation": "Implement strong authentication mechanisms such as multi-factor authentication (MFA), \nsecure password policies, and session management with secure tokens.",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 1,
                  "score": ""
                },
                {
                  "id": "7a8fb1fc-035d-428d-b746-0cfa7930aa32",
                  "title": "HTTP Request Tampering",
                  "status": "Open",
                  "severity": "Medium",
                  "type": "Tampering",
                  "description": "An attacker could intercept and modify HTTP requests between the user and the web application to alter request parameters or inject malicious data.",
                  "mitigation": "Use HTTPS encryption, implement input validation, and verify request integrity.",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 2,
                  "score": ""
                },
                {
                  "id": "d624298a-0dc1-472f-9c10-7d5acd02ab00",
                  "title": "API Request Manipulation",
                  "status": "Open",
                  "severity": "High",
                  "type": "Tampering",
                  "description": "An attacker could modify or manipulate API requests sent to the web application \nto alter system behavior or gain unauthorized access to data.",
                  "mitigation": "Implement server-side input validation, use HTTPS encryption, \nand apply request integrity checks to prevent request tampering.",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 3,
                  "score": ""
                }
